# ============================================================
# PLANTMIND AI - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# DO NOT COMMIT .env FILE - it contains secrets!
# ============================================================

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:password@localhost:5432/plantmind

# ============================================================
# APPLICATION SETTINGS
# ============================================================
APP_SECRET_KEY=your-secret-key-here-change-in-production
APP_HOST=0.0.0.0
APP_PORT=8000
SESSION_MAX_AGE_SECONDS=28800
SESSION_COOKIE_NAME=plantmind_session

# ============================================================
# GMAIL API (FOR READING EMAILS)
# ============================================================
# 1. Go to Google Cloud Console: https://console.cloud.google.com/
# 2. Create a project and enable Gmail API
# 3. Create OAuth 2.0 credentials (Desktop App)
# 4. Download credentials.json to config/ folder
GMAIL_TOKEN_PATH=config/token.json
GMAIL_CLIENT_SECRET=config/credentials.json

# ============================================================
# OLLAMA (LOCAL AI MODELS)
# ============================================================
OLLAMA_API_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=mistral:7b-instruct-q4_K_M
OLLAMA_PHI3_MODEL=phi3:mini
OLLAMA_TIMEOUT_SECONDS=180
OLLAMA_PHI3_TIMEOUT_SECONDS=120
OLLAMA_HOST=http://localhost:11434

# ============================================================
# GMAIL SMTP (FOR SENDING EMAILS)
# ============================================================
# 1. Enable 2-Step Verification in your Google Account
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use the 16-character app password below
GMAIL_SMTP_SERVER=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_SMTP_EMAIL=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# ============================================================
# FACTORY OWNER CONFIGURATION
# ============================================================
# Email where owner receives alerts and daily MIS reports
OWNER_EMAIL=owner@yourfactory.com
OWNER_REPORT_EMAIL=owner@yourfactory.com
FACTORY_NAME=Your Factory Name

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO

# ============================================================
# DEFAULT USER PASSWORDS
# ============================================================
# IMPORTANT: Change these in production!
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_OFFICE_PASSWORD=office123
DEFAULT_OWNER_PASSWORD=owner123
DEFAULT_SUPERVISOR_PASSWORD=supervisor123
DEFAULT_STORE_PASSWORD=store123

# ============================================================
# BOOTSTRAP CONTROL
# ============================================================
# Set to false after first run in production to prevent
# accidental user recreation
BOOTSTRAP_DEFAULT_USERS=true

# ============================================================
# DATABASE POOL SETTINGS
# ============================================================
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=1800

# ============================================================
# RATE LIMITING
# ============================================================
LOGIN_ATTEMPT_WINDOW_SECONDS=300
LOGIN_MAX_ATTEMPTS=5